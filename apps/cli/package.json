{
  "name": "tascal-cli",
  "version": "0.1.1",
  "description": "tascal CLI — カレンダータスク管理",
  "type": "module",
  "bin": {
    "tascal": "dist/src/index.js",
    "tascal-cli": "dist/src/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hirokisakabe/tascal",
    "directory": "apps/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cli",
    "task",
    "calendar"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3"
  }
}
