{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://tascal-api.example.com"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://tascal-api.example.com"
      }
    }
  }
}
